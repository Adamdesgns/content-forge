{
  "name": "lucedale-content-forge-desktop",
  "version": "0.8.0",
  "description": "Simple platform-first desktop content generator for Lucedale Logo and the Anvil Content Forge module.",
  "main": "main.js",
  "author": "Lucedale Logo",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win portable",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.lucedalelogo.contentforge",
    "productName": "Lucedale Content Forge",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "prompts/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
